	column 'Customer Name'
		dataType: string
		lineageTag: e555dc2d-c325-46e6-9c82-31721e257456
		summarizeBy: none
		sourceColumn: Customer Name

	column Segment
		dataType: string
		lineageTag: 5c23639f-c6b9-4e2d-bb15-c7f9eac71ebe
